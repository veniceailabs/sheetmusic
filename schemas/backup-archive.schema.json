{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sheetmusic.app/schemas/backup-archive.schema.json",
  "title": "Sheet Music Backup Archive Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "formatVersion",
    "createdAt",
    "product",
    "library",
    "artifacts"
  ],
  "properties": {
    "formatVersion": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+$"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "product": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "appVersion"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "appVersion": {
          "type": "string"
        }
      }
    },
    "library": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scoreCount",
        "setlistCount",
        "annotationCount"
      ],
      "properties": {
        "scoreCount": {
          "type": "integer",
          "minimum": 0
        },
        "setlistCount": {
          "type": "integer",
          "minimum": 0
        },
        "annotationCount": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "kind",
          "path",
          "sha256"
        ],
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "document",
              "thumbnail",
              "annotation",
              "media",
              "settings",
              "metadata",
              "project_reference"
            ]
          },
          "path": {
            "type": "string"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-fA-F0-9]{64}$"
          }
        }
      }
    },
    "encryption": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "none",
            "aes-256-gcm"
          ]
        },
        "keyDerivation": {
          "type": "string"
        }
      }
    }
  }
}
